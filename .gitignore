# =====================================================
# SleepSense AI - Full Stack .gitignore
# =====================================================

# =====================================================
# Environment Variables
# =====================================================
.env
.env.*
!.env.example

frontend/.env
frontend/.env.*
!frontend/.env.example

backend/.env
backend/.env.*
!backend/.env.example

ai-service/.env
ai-service/.env.*
!ai-service/.env.example

# =====================================================
# Node.js Dependencies
# =====================================================
node_modules/
frontend/node_modules/
backend/node_modules/

# Package manager logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =====================================================
# Frontend Build Files (Vite/React)
# =====================================================
frontend/dist/
frontend/build/
dist/
build/

# Vite cache
.vite/

# =====================================================
# Backend Build / Logs
# =====================================================
backend/dist/
backend/build/

logs/
*.log

# =====================================================
# Python / FastAPI
# =====================================================
__pycache__/
*.py[cod]
*$py.class

# Python virtual environments
venv/
env/
ENV/
.venv/

# Python cache/testing
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.hypothesis/

# Coverage
.coverage
.coverage.*
htmlcov/

# =====================================================
# AI Model Files
# =====================================================
ai-service/model/*.pkl
ai-service/model/*.joblib
ai-service/model/*.h5
ai-service/model/*.pt

# =====================================================
# Jupyter Notebook
# =====================================================
.ipynb_checkpoints/

# =====================================================
# Python Build Files
# =====================================================
*.egg-info/
.eggs/
pip-wheel-metadata/

# =====================================================
# Database / Local Storage
# =====================================================
data/db/
*.sqlite
*.sqlite3

# =====================================================
# Uploads / Reports
# =====================================================
uploads/
backend/reports/
*.pdf

# =====================================================
# Deployment Platforms
# =====================================================

# Vercel
.vercel/

# Render
.render/

# Netlify
.netlify/

# =====================================================
# IDE / Editor Files
# =====================================================
.vscode/
.idea/

*.swp
*.swo
*.tmp
*.temp

# =====================================================
# OS Files
# =====================================================
.DS_Store
Thumbs.db
desktop.ini

# =====================================================
# Temporary Files
# =====================================================
tmp/
temp/
.cache/

# =====================================================
# Misc
# =====================================================
*.bak
*.old
*.orig

# =====================================================
# Optional Lock Files
# (Uncomment if needed)
# =====================================================

# package-lock.json
# yarn.lock
# pnpm-lock.yaml